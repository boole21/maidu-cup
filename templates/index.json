    "heading_with_text_GcEE9W": {
      "type": "heading-with-text",
      "name": "Heading with Text",
      "settings": {
        "heading": "A Millennium's Craft A Gift of Soul",
        "button_text": "Our Story",
        "button_link": "/",
        "text_content": "<p><strong>Tenmoku</strong> Jianzhan tea cups, a fusion of Japanese and Chinese millennium-old craftsmanship, are globally renowned for their handmade artistry, natural iron-rich glaze, and unique kiln-transformed patterns like \"oil spot\" and \"hare's fur.\" Each cup uses 100% food-safe mineral glaze, where high iron content creates rare textures that evolve with use. Exceptional heat retention keeps tea warmer longer, enhancing flavor complexity with every sip—ideal for tea enthusiasts' wellness rituals and fine art collectors' treasures. With scarce hand-glazed designs and cultural storytelling packaging, <strong>Tenmoku</strong> is the ultimate luxury gift for conveying Eastern heritage and artisan legacy.</p>",
        "color_scheme": "default",
        "section_padding": 60
      }
