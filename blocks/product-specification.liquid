      "label": "t:settings.show_diameter",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_depth",
      "label": "t:settings.show_depth",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_heat_resistant",
      "label": "t:settings.show_heat_resistant",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_food_safe",
      "label": "t:settings.show_food_safe",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_dishwasher",
      "label": "t:settings.show_dishwasher",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_microwave",
      "label": "t:settings.show_microwave",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_direct_heat",
      "label": "t:settings.show_direct_heat",
      "default": true
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
