{%- assign block_settings = block.settings -%}

{%- liquid
  # Generate inline SVG icon
  assign icon_svg = ''
  if block_settings.icon == 'sparkle'
    assign icon_svg = '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/></svg>'
  elsif block_settings.icon == 'snowflake'
    assign icon_svg = '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="2" x2="22" y1="12" y2="12"/><line x1="12" x2="12" y1="2" y2="22"/><path d="m20 16-4-4 4-4"/><path d="m4 8 4 4-4 4"/><path d="m16 4-4 4-4-4"/><path d="m8 20 4-4 4 4"/></svg>'
  elsif block_settings.icon == 'star'
    assign icon_svg = '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>'
  elsif block_settings.icon == 'gift'
    assign icon_svg = '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="8" width="18" height="4" rx="1"/><path d="M12 8v13"/><path d="M19 12v7a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2v-7"/><path d="M7.5 8a2.5 2.5 0 0 1 0-5 2.5 2.5 0 0 1 2.5 2.5v5"/><path d="M16.5 8v-2.5a2.5 2.5 0 0 1 5 0 2.5 2.5 0 0 1-2.5 2.5h-5"/></svg>'
  elsif block_settings.icon == 'tag'
    assign icon_svg = '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12.586 2.586A2 2 0 0 0 11.172 2H4a2 2 0 0 0-2 2v7.172a2 2 0 0 0 .586 1.414l8.704 8.704a2.426 2.426 0 0 0 3.42 0l6.58-6.58a2.426 2.426 0 0 0 0-3.42z"/><circle cx="7.5" cy="7.5" r=".5"/></svg>'
  elsif block_settings.icon == 'heart'
    assign icon_svg = '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>'
  elsif block_settings.icon == 'fire'
    assign icon_svg = '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z"/></svg>'
  elsif block_settings.icon == 'lightning_bolt'
    assign icon_svg = '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2 3 14h9l-1 8 10-12h-9l1-8z"/></svg>'
  endif

  # Handle custom heading font size
  if block_settings.heading_preset == 'custom'
    assign heading_font_size = block_settings.custom_heading_font_size | append: 'px'
  else
    assign heading_font_size = 'var(--font-' | append: block_settings.heading_preset | append: '--size)'
  endif
-%}

<div
  class="product-promo product-promo--{{ block.id }} spacing-style{% if block_settings.inherit_color_scheme == false %} color-{{ block_settings.color_scheme }}{% endif %}"
  style="
    --promo-background: {{ block_settings.background_color }};
    --promo-text-color: {{ block_settings.text_color }};
    --promo-border-radius: {{ block_settings.border_radius }}px;
    --promo-padding: {{ block_settings.padding }}px;
    --promo-heading-font-family: {% if block_settings.heading_preset == 'custom' %}var(--font-heading--family){% else %}var(--font-{{ block_settings.heading_preset }}--family){% endif %};
    --promo-heading-font-style: {% if block_settings.heading_preset == 'custom' %}normal{% else %}var(--font-{{ block_settings.heading_preset }}--style){% endif %};
    --promo-heading-font-weight: {% if block_settings.heading_preset == 'custom' %}var(--font-heading--weight){% else %}var(--font-{{ block_settings.heading_preset }}--weight){% endif %};
    --promo-heading-font-size: {{ heading_font_size }};
    --promo-heading-font-line-height: {% if block_settings.heading_preset == 'custom' %}1.2{% else %}var(--font-{{ block_settings.heading_preset }}--line-height){% endif %};
    --promo-heading-font-case: {% if block_settings.heading_preset == 'custom' %}none{% else %}var(--font-{{ block_settings.heading_preset }}--case){% endif %};
    --promo-text-align: {{ block_settings.text_alignment }};
  "
  {{ block.shopify_attributes }}
>
  <div class="product-promo__inner">
    <div class="product-promo__content">
      {%- if block_settings.icon != 'none' -%}
        <div class="product-promo__icon product-promo__icon--left">
          {{ icon_svg }}
        </div>
      {%- endif -%}

      {%- if block_settings.heading != blank -%}
        <div class="product-promo__heading">
          {{ block_settings.heading }}
        </div>
      {%- endif -%}

      {%- if block_settings.icon != 'none' -%}
        <div class="product-promo__icon product-promo__icon--right">
          {{ icon_svg }}
        </div>
      {%- endif -%}
    </div>

    {%- if block_settings.text != blank -%}
      <div class="product-promo__text rte">
        {{ block_settings.text }}
      </div>
    {%- endif -%}
  </div>
</div>

{% stylesheet %}
  .product-promo {
    display: flex;
    flex-direction: column;
    align-items: var(--promo-text-align, center);
    text-align: var(--promo-text-align, center);
  }

  .product-promo__inner {
    background-color: var(--promo-background, transparent);
    border-radius: var(--promo-border-radius, 0);
    padding: var(--promo-padding, 32px);
    display: flex;
    flex-direction: column;
    align-items: var(--promo-text-align, center);
    gap: var(--gap-xs);
    width: 100%;
  }

  .product-promo__content {
    display: flex;
    align-items: center;
    justify-content: var(--promo-text-align, center);
    gap: var(--gap-sm);
    flex-wrap: wrap;
  }

  .product-promo__heading {
    font-family: var(--promo-heading-font-family);
    font-style: var(--promo-heading-font-style);
    font-weight: var(--promo-heading-font-weight);
    font-size: var(--promo-heading-font-size);
    line-height: var(--promo-heading-font-line-height);
    text-transform: var(--promo-heading-font-case);
    color: var(--promo-text-color, var(--color-foreground));
  }

  .product-promo__text {
    font-size: var(--font-paragraph--size);
    line-height: var(--font-paragraph--line-height);
    color: var(--promo-text-color, var(--color-foreground));
  }

  .product-promo__icon {
    color: var(--promo-text-color, var(--color-foreground));
  }

  .product-promo__icon {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .product-promo__icon svg {
    width: 100%;
    height: 100%;
  }

  .product-promo__text p {
    margin: 0;
  }

  .product-promo__text p + p {
    margin-top: var(--margin-xs);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.product_promo",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "CHRISTMAS SALE"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Up to 30% OFF Everything!</p>"
    },
    {
      "type": "header",
      "content": "Icon"
    },
    {
      "type": "select",
      "id": "icon",
      "label": "Icon",
      "options": [
        {
          "value": "none",
          "label": "None"
        },
        {
          "value": "sparkle",
          "label": "Sparkle"
        },
        {
          "value": "snowflake",
          "label": "Snowflake"
        },
        {
          "value": "star",
          "label": "Star"
        },
        {
          "value": "gift",
          "label": "Gift"
        },
        {
          "value": "tag",
          "label": "Tag"
        },
        {
          "value": "heart",
          "label": "Heart"
        },
        {
          "value": "fire",
          "label": "Fire"
        },
        {
          "value": "lightning_bolt",
          "label": "Lightning"
        }
      ],
      "default": "sparkle"
    },
    {
      "type": "header",
      "content": "Appearance"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#FFFBEB"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#b45309"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 10
    },
    {
      "type": "select",
      "id": "heading_preset",
      "label": "Heading preset",
      "options": [
        {
          "value": "h1",
          "label": "H1"
        },
        {
          "value": "h2",
          "label": "H2"
        },
        {
          "value": "h3",
          "label": "H3"
        },
        {
          "value": "h4",
          "label": "H4"
        },
        {
          "value": "h5",
          "label": "H5"
        },
        {
          "value": "h6",
          "label": "H6"
        },
        {
          "value": "custom",
          "label": "Custom"
        }
      ],
      "default": "h4"
    },
    {
      "type": "range",
      "id": "custom_heading_font_size",
      "label": "Custom heading font size",
      "min": 12,
      "max": 72,
      "step": 1,
      "unit": "px",
      "default": 24,
      "visible_if": "{{ block.settings.heading_preset == 'custom' }}"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Alignment",
      "options": [
        {
          "value": "flex-start",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "flex-end",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "checkbox",
      "id": "inherit_color_scheme",
      "label": "Inherit color scheme",
      "default": true
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1",
      "visible_if": "{{ block.settings.inherit_color_scheme == false }}"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding",
      "label": "Padding",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 32
    }
  ],
  "presets": [
    {
      "name": "t:names.product_promo",
      "category": "t:categories.product",
      "settings": {
        "heading": "CHRISTMAS SALE",
        "text": "<p>Up to 30% OFF Everything!</p>",
        "icon": "sparkle",
        "background_color": "#FFFBEB",
        "text_color": "#b45309",
        "border_radius": 10,
        "heading_preset": "h4",
        "text_alignment": "center",
        "inherit_color_scheme": true,
        "padding": 32
      }
    }
  ]
}
{% endschema %}
