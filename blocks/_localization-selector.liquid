{%- liquid
  assign show_language = block.settings.show_language
  if localization.available_languages.size <= 1
    assign show_language = false
  endif

  assign show_country = block.settings.show_country
  if localization.available_countries.size <= 1
    assign show_country = false
  endif

  assign localization_font = '--menu-localization-font: var(--font-[localization_font]--family); ' | replace: '[localization_font]', block.settings.localization_font
  assign localization_font_size = '--menu-localization-font-size: [localization_font_size]; ' | replace: '[localization_font_size]', block.settings.localization_font_size
  assign color_shadow = '--color-shadow: rgb(var(--color-foreground-rgb) / var(--opacity-10-25));'
  assign form_style = localization_font | append: localization_font_size | append: color_shadow
-%}

{%- if show_language or show_country -%}
  <div
    class="localization-selector-block"
    style="{{ form_style }}"
    {{ block.shopify_attributes }}
  >
    {%- if show_language and show_country == false -%}
      {% comment %} 仅语言选择器 - 内联样式 {% endcomment %}
      <dropdown-localization-component class="dropdown-localization">
        <button
          type="button"
          class="button dropdown-localization__button localization-selector"
          aria-expanded="false"
          aria-controls="dropdown-localization-results-{{ block.id }}"
          ref="button"
          on:click="/toggleSelector"
          style="{{ localization_font }} {{ localization_font_size }}"
        >
          <span>{{ localization.language.iso_code | upcase }}</span>
          <span class="svg-wrapper icon-caret">
            {{- 'icon-caret.svg' | inline_asset_content -}}
          </span>
        </button>

        <div
          class="localization-wrapper right-bound color-{{ settings.popover_color_scheme }}"
          hidden
          ref="panel"
          id="dropdown-localization-results-{{ block.id }}"
        >
          {% render 'localization-form',
            show_country: show_country,
            show_language: show_language,
            localization_style: 'dropdown',
            form_style: form_style,
            form_id: block.id
          %}
        </div>
      </dropdown-localization-component>
    {%- elsif show_country -%}
      {% comment %} 货币/国家选择器 - 下拉菜单样式 {% endcomment %}
      <dropdown-localization-component class="dropdown-localization">
        <button
          type="button"
          class="button dropdown-localization__button localization-selector"
          aria-expanded="false"
          aria-controls="dropdown-localization-results-{{ block.id }}"
          ref="button"
          on:click="/toggleSelector"
          style="{{ localization_font }} {{ localization_font_size }}"
        >
          {%- if show_country -%}
            {%- if block.settings.show_flag -%}
              <span
                class="icon-flag"
                style="
                  background-image: url({{- localization.country | image_url: width: 32 -}});
                  --size-shadow: 2px;
                  --color-shadow: rgb(var(--color-foreground-rgb) / var(--opacity-30-60));
                "
              ></span>
            {%- endif -%}
            <span class="currency-code" data-testid="localization-currency-code">
              {{- localization.country.currency.iso_code -}}
            </span>
          {%- endif -%}

          {%- if show_country and show_language -%}
            <span>/</span>
          {%- endif -%}

          {%- if show_language -%}
            <span>{{ localization.language.iso_code | upcase }}</span>
          {%- endif -%}
          <span class="svg-wrapper icon-caret">
            {{- 'icon-caret.svg' | inline_asset_content -}}
          </span>
        </button>

        <div
          class="localization-wrapper right-bound color-{{ settings.popover_color_scheme }}"
          hidden
          ref="panel"
          id="dropdown-localization-results-{{ block.id }}"
        >
          {% render 'localization-form',
            show_country: show_country,
            show_language: show_language,
            localization_style: 'dropdown',
            form_style: form_style,
            form_id: block.id
          %}
        </div>
      </dropdown-localization-component>
    {%- endif -%}
  </div>
{%- endif -%}

{% stylesheet %}
  .localization-selector-block {
    display: flex;
    align-items: center;
  }

  .localization-selector-block .dropdown-localization {
    display: flex;
    align-items: center;
  }

  .localization-selector-block .dropdown-localization__button {
    display: flex;
    position: relative;
    align-items: center;
    gap: 4px;
    font-family: var(--menu-localization-font);
    font-size: var(--menu-localization-font-size);
    font-weight: var(--menu-top-level-font-weight, 400);
    padding-inline: var(--padding-2xs);
    margin-inline: calc(-1 * var(--padding-2xs));
    color: inherit;
    background: transparent;
    border: none;
    cursor: pointer;
  }

  .localization-selector-block .dropdown-localization__button .svg-wrapper.icon-caret {
    height: var(--icon-size-xs);
    width: var(--icon-size-xs);
    flex-shrink: 0;
    transition: transform var(--animation-speed) var(--animation-easing);
  }

  .localization-selector-block .dropdown-localization__button .icon-flag {
    width: var(--menu-localization-font-size, var(--icon-size-sm));
    height: var(--menu-localization-font-size, var(--icon-size-sm));
    clip-path: circle(50%);
    background-position: center;
    background-size: cover;
    margin-inline-end: 4px;
    position: relative;
  }

  .localization-selector-block .dropdown-localization__button .icon-flag::after {
    content: '';
    position: absolute;
    inset: 0;
    box-shadow: inset 0 0 var(--size-shadow, 2px) var(--color-shadow);
    border-radius: 50%;
  }

  .localization-selector-block .dropdown-localization__button[aria-expanded='true'] .icon-caret svg {
    transform: rotate(180deg);
  }

  .localization-selector-block dropdown-localization-component {
    position: relative;
    background-color: transparent;
  }

  .localization-selector-block dropdown-localization-component .localization-wrapper {
    box-shadow: var(--shadow-popover);
    border: var(--style-border-popover);
    background-color: var(--color-background);
    max-height: 27.5rem;
    position: absolute;
    top: calc(100% + 10px);
    right: 0;
    z-index: calc(var(--layer-header-menu) + 1);
    border-radius: var(--style-border-radius-popover);
    transition-property: display, opacity, translate;
    transition-duration: 0.3s;
    transition-timing-function: var(--ease-out-quad);
    transition-behavior: allow-discrete;
    translate: 0 20px;
    opacity: 0;
  }

  .localization-selector-block dropdown-localization-component .localization-wrapper:not([hidden]) {
    translate: 0 0;
    opacity: 1;
  }

  @starting-style {
    .localization-selector-block dropdown-localization-component .localization-wrapper:not([hidden]) {
      translate: 0 20px;
      opacity: 0;
    }
  }

  .localization-selector-block dropdown-localization-component .localization-form__list {
    max-height: 20.5rem;
  }

  .localization-selector-block dropdown-localization-component .country-filter {
    position: relative;
    padding: 8px;
  }

  .localization-selector-block dropdown-localization-component .country-filter__input {
    border: none;
  }

  .localization-selector-block dropdown-localization-component .localization-form__list-item {
    margin-inline: 8px;
  }

  .localization-selector-block dropdown-localization-component .language-selector.language-selector {
    padding: 10px 8px 10px 16px;
  }

  .localization-selector-block dropdown-localization-component .localization-form__currency {
    width: max-content;
    opacity: 0;
    visibility: hidden;
    transition: none;
  }

  .localization-selector-block dropdown-localization-component .localization-form__select:hover {
    background-color: rgb(var(--color-primary-hover-rgb) / var(--opacity-8));
  }

  .localization-selector-block
    dropdown-localization-component
    :is(
      .localization-form__list-item:hover,
      .localization-form__list-item[aria-selected='true'],
      .localization-form__list-item[aria-current='true']
    )
    .localization-form__currency {
    opacity: 1;
    color: var(--color-foreground-muted);
    transition: opacity var(--animation-speed-slow) var(--animation-easing);
    visibility: visible;
  }

  .localization-selector-block .dropdown-localization .language-selector:where(:not(.top-shadow)) {
    font-weight: var(--menu-top-level-font-weight, 400);
  }

  .localization-selector-block .dropdown-localization:not(dropdown-localization-component) .language-selector {
    font-family: var(--menu-localization-font);
    font-size: var(--menu-localization-font-size);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.localization_selector",
  "settings": [
    {
      "type": "header",
      "content": "t:content.localization"
    },
    {
      "type": "checkbox",
      "id": "show_country",
      "label": "t:settings.show_country",
      "info": "t:info.manage_countries",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_flag",
      "label": "t:settings.show_flag",
      "default": true,
      "visible_if": "{{ block.settings.show_country }}"
    },
    {
      "type": "checkbox",
      "id": "show_language",
      "label": "t:settings.show_language",
      "info": "t:info.manage_languages",
      "default": true
    },
    {
      "type": "header",
      "content": "t:content.typography"
    },
    {
      "type": "select",
      "id": "localization_font",
      "label": "t:settings.font",
      "options": [
        {
          "value": "heading",
          "label": "t:options.heading"
        },
        {
          "value": "subheading",
          "label": "t:options.subheading"
        },
        {
          "value": "body",
          "label": "t:options.body"
        },
        {
          "value": "accent",
          "label": "t:options.accent"
        }
      ],
      "default": "heading"
    },
    {
      "type": "select",
      "id": "localization_font_size",
      "label": "t:settings.size",
      "options": [
        {
          "value": "0.625rem",
          "label": "10px"
        },
        {
          "value": "0.75rem",
          "label": "12px"
        },
        {
          "value": "0.875rem",
          "label": "14px"
        },
        {
          "value": "1rem",
          "label": "16px"
        },
        {
          "value": "1.125rem",
          "label": "18px"
        }
      ],
      "default": "1rem"
    }
  ],
  "presets": [
    {
      "name": "t:names.localization_selector",
      "settings": {
        "show_country": true,
        "show_flag": true,
        "show_language": true,
        "localization_font": "heading",
        "localization_font_size": "1rem"
      }
    }
  ]
}
{% endschema %}
