<div class="sub-title">
  {% if closest.collection == blank %}
    {% assign sub_title = 'placeholders.collection_sub_title' | t %}
    {% assign sub_title_html = '<p>' | append: sub_title | append: '</p>' %}
    {% render 'text', fallback_text: sub_title_html, block: block %}
  {% elsif closest.collection != blank %}
    {% assign sub_title = closest.collection.metafields.custom.sub_title %}
    {% if sub_title != blank %}
      {% assign sub_title_html = '<p>' | append: sub_title | append: '</p>' %}
      {% render 'text', fallback_text: sub_title_html, block: block %}
    {% endif %}
  {% endif %}
</div>

{% schema %}
{
  "name": "t:names.collection_sub_title",
  "tag": null,
  "settings": [
    {
      "type": "paragraph",
      "content": "t:content.resource_reference_collection_sub_title"
    },
    {
      "type": "header",
      "content": "t:content.layout"
    },
    {
      "type": "select",
      "id": "width",
      "label": "t:settings.width",
      "options": [
        {
          "value": "fit-content",
          "label": "t:options.fit"
        },
        {
          "value": "100%",
          "label": "t:options.fill"
        }
      ],
      "default": "fit-content"
    },
    {
      "type": "select",
