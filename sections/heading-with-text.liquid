{% liquid
  assign heading = section.settings.heading
  assign button_text = section.settings.button_text
  assign button_link = section.settings.button_link
  assign text_content = section.settings.text_content
  assign color_scheme = section.settings.color_scheme
  assign section_padding = section.settings.section_padding
%}

<div class="section section--padding color-{{ color_scheme }}" style="--section-padding: {{ section_padding }}px;">
  <div class="page-width">
    <div class="tw-grid grid-cols-1 md:grid-cols-[2fr_3fr] gap-8 md:gap-16 items-center">
      <!-- Left side: Heading + Button -->
      <div class="flex flex-col gap-8">
        {% if heading != blank %}
          <h2 class="heading title-lg leading-none">
            {{ heading }}
          </h2>
        {% endif %}

        {% if button_text != blank and button_link != blank %}
          <div>
            <a
              href="{{ button_link }}"
              class="btn-animated inline-flex items-center gap-2 px-6 py-3 border-2 border-current rounded-full relative overflow-hidden transition-colors duration-300"
            >
              <span class="btn-text relative z-10">{{ button_text }}</span>
              <svg
                class="w-4 h-4 relative z-10"
                viewBox="0 0 21 20"
                stroke="currentColor"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 10H18M18 10L12.1667 4.16675M18 10L12.1667 15.8334"></path>
              </svg>
            </a>
          </div>
        {% endif %}
      </div>

      <!-- Right side: Text content -->
      {% if text_content != blank %}
        <div class="rich-text rte body">
          {{ text_content }}
        </div>
      {% endif %}
    </div>
  </div>
</div>

{% stylesheet %}
  .section--padding {
    padding-block: var(--section-padding, var(--padding-section));
  }

  /* Tailwind CSS grid utility using tw-grid class to avoid conflict with Horizon theme */
  .tw-grid {
    display: grid;
  }

  /* Button with wave animation - black enters from bottom, white enters from top */
  .btn-animated {
    position: relative;
    overflow: hidden;
    transition: color 0.8s cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* Black wave - enters from bottom on hover */
  .btn-animated::before {
    content: '';
    position: absolute;
    bottom: -150%;
    left: 50%;
    width: 250%;
    height: 250%;
    background: black;
    border-radius: 50%;
    transform: translateX(-50%) scale(0.2);
    transform-origin: center center;
    transition: transform 0.8s cubic-bezier(0.4, 0, 0.2, 1), bottom 0.8s cubic-bezier(0.4, 0, 0.2, 1);
    z-index: 1;
  }

  .btn-animated:hover::before {
    bottom: -50%;
    transform: translateX(-50%) scale(1);
  }

  /* White wave - enters from top on mouse leave to cover black (opposite direction) */
  .btn-animated::after {
    content: '';
    position: absolute;
    top: -150%;
    left: 50%;
    width: 250%;
    height: 250%;
    background: white;
    border-radius: 50%;
    transform: translateX(-50%) scale(0.2);
    transform-origin: center center;
    transition: transform 0.8s cubic-bezier(0.4, 0, 0.2, 1), top 0.8s cubic-bezier(0.4, 0, 0.2, 1);
    z-index: 2;
    opacity: 0;
  }

  .btn-animated:not(:hover)::after {
    top: -50%;
    transform: translateX(-50%) scale(1);
    opacity: 1;
  }

  .btn-animated:hover {
    color: white;
  }

  .btn-animated:not(:hover) {
    color: black;
  }

  .btn-animated .btn-text,
  .btn-animated svg {
    position: relative;
    z-index: 10;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Heading with Text",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "A Millennium's Craft A Gift of Soul"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Our Story"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link",
      "default": "/"
    },
    {
      "type": "richtext",
      "id": "text_content",
      "label": "Text content",
      "default": "<p><strong>Tenmoku</strong> Jianzhan tea cups, a fusion of Japanese and Chinese millennium-old craftsmanship, are globally renowned for their handmade artistry, natural iron-rich glaze, and unique kiln-transformed patterns like \"oil spot\" and \"hare's fur.\" Each cup uses 100% food-safe mineral glaze, where high iron content creates rare textures that evolve with use. Exceptional heat retention keeps tea warmer longer, enhancing flavor complexity with every sip—ideal for tea enthusiasts' wellness rituals and fine art collectors' treasures. With scarce hand-glazed designs and cultural storytelling packaging, <strong>Tenmoku</strong> is the ultimate luxury gift for conveying Eastern heritage and artisan legacy.</p>"
    },
    {
      "type": "header",
      "content": "Appearance"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Color scheme",
      "options": [
        {
          "value": "default",
          "label": "Default"
        },
        {
          "value": "inverse",
          "label": "Inverse"
        },
        {
          "value": "accent",
          "label": "Accent"
        }
      ],
      "default": "default"
    },
    {
      "type": "range",
      "id": "section_padding",
      "label": "Section padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "Heading with Text",
      "category": "t:categories.text"
    }
  ]
}
{% endschema %}
