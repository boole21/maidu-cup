{% liquid
  assign bg_color = section.settings.color_scheme.settings.background
%}
<div
  class="header-top spacing-style section section--{{ section.settings.section_width }} color-{{ section.settings.color_scheme }}"
  style="{% render 'spacing-padding', settings: section.settings %}; --border-bottom-width: {{ section.settings.divider_width }}px; background-color: {{ bg_color }};"
>
  <div class="header-top__container">
    {%- comment -%} Left: Social Icons {%- endcomment -%}
    <div class="header-top__left">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'social-links' -%}
            <div class="social-icons__wrapper" {{ block.shopify_attributes }}>
              {% liquid
                assign social_links = 'social_facebook_url,social_instagram_url,social_youtube_url,social_tiktok_url,social_twitter_url,social_threads_url,social_linkedin_url,social_bluesky_url,social_snapchat_url,social_pinterest_url,social_tumblr_url,social_vimeo_url,social_custom_url' | split: ','
                assign platform_names = 'facebook,instagram,youtube,tiktok,twitter,threads,linkedin,bluesky,snapchat,pinterest,tumblr,vimeo,custom' | split: ','
              %}
              {% for link_key in social_links %}
                {% liquid
                  assign link_url = settings[link_key]
                  assign platform = platform_names[forloop.index0]
                  assign render_icon = true

                  if link_url != blank
                    if platform == 'custom'
                      assign platform = link_url | split: '//' | last | remove: 'www.' | split: '.' | first
                      case platform
                        when 'x'
                          assign platform = 'twitter'
                        else
                          assign render_icon = false
                      endcase
                    endif

                    assign url_parts = link_url | split: '//' | last | split: '/'
                    assign has_profile = false
                    if url_parts.size > 1 and url_parts[1] != ''
                      assign has_profile = true
                    endif
                    unless render_icon
                      assign has_profile = true
                    endunless
                  endif
                %}
                {% if link_url != blank %}
                  {% if request.design_mode or has_profile %}
                    <div class="social-icons__icon-wrapper{% unless has_profile %} social-icons__icon-wrapper--disabled{% endunless %}">
                      <a
                        href="{{ link_url }}"
                        target="_blank"
                        rel="noopener noreferrer"
                        aria-label="{{ platform | capitalize }}"
                        {% unless has_profile %}
                          {% if request.design_mode %}
                            onclick="return false;"
                            aria-disabled="true"
                          {% endif %}
                        {% endunless %}
                      >
                        <span class="social-icons__icon-label">{{ platform | capitalize }}</span>
                        {% if render_icon %}
                          <svg
                            class="social-icons__icon icon-default"
                            aria-hidden="true"
                            focusable="false"
                            xmlns="http://www.w3.org/2000/svg"
                            viewBox="0 0 20 20"
                          >
                            {%- render 'icon', icon: platform -%}
                          </svg>
                        {% endif %}
                      </a>
                    </div>
                  {% endif %}
                {% endif %}
              {% endfor %}
            </div>
        {%- endcase -%}
      {%- endfor -%}
    </div>

    {%- comment -%} Center: Announcement Text {%- endcomment -%}
    <div class="header-top__center">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'announcement' -%}
            {%- assign plain_text = block.settings.text | strip_newlines | strip_html | strip -%}
            {%- unless plain_text == '' -%}
              <div
                class="header-top__announcement text-block custom-typography"
                style="{% render 'typography-style', settings: block.settings, preset: 'custom' %}"
                {{ block.shopify_attributes }}
              >
                <p class="header-top__text">
                  {{ block.settings.text }}
                </p>
                {%- if block.settings.link != blank -%}
                  <a class="header-top__link" href="{{ block.settings.link }}">
                    <span class="visually-hidden">{{ block.settings.text | strip_html }}</span>
                  </a>
                {%- endif -%}
              </div>
            {%- endunless -%}
        {%- endcase -%}
      {%- endfor -%}
    </div>

    {%- comment -%} Right: Localization Selector {%- endcomment -%}
    <div class="header-top__right">
      {%- liquid
        assign show_language = section.settings.show_language
        if localization.available_languages.size <= 1
          assign show_language = false
        endif

        assign show_country = section.settings.show_country
        if localization.available_countries.size <= 1
          assign show_country = false
        endif
      -%}

      {%- if show_language or show_country -%}
        {% liquid
          assign localization_font = '--menu-localization-font: var(--font-[localization_font]--family); ' | replace: '[localization_font]', section.settings.localization_font
          assign localization_font_size = '--menu-localization-font-size: [localization_font_size]; ' | replace: '[localization_font_size]', section.settings.localization_font_size
          assign color_shadow = '--color-shadow: rgb(var(--color-foreground-rgb) / var(--opacity-10-25));'
          assign form_style = localization_font | append: localization_font_size | append: color_shadow
        %}
        {% if show_language and show_country == false %}
          <div class="dropdown-localization">
            {% render 'localization-form',
              show_country: show_country,
              show_language: show_language,
              localization_style: 'dropdown',
              form_style: form_style,
              form_id: section.id
            %}
          </div>
        {% elsif show_country %}
          <dropdown-localization-component class="dropdown-localization">
            <button
              type="button"
              class="button dropdown-localization__button localization-selector"
              aria-expanded="false"
              aria-controls="dropdown-localization-results-{{ section.id }}"
              ref="button"
              on:click="/toggleSelector"
              style="{{ localization_font }} {{ localization_font_size }}"
            >
              {% if show_country %}
                {% if section.settings.country_selector_style == true %}
                  <span
                    class="icon-flag"
                    style="
                      background-image: url({{- localization.country | image_url: width: 32 }});
                      --size-shadow: 2px;
                      --color-shadow: rgb(var(--color-foreground-rgb) / var(--opacity-30-60));
                    "
                  ></span>
                {% endif %}
                <span class="currency-code" data-testid="localization-currency-code">
                  {{- localization.country.currency.iso_code -}}
                </span>
              {% endif %}
              <span class="visually-hidden" data-testid="localization-visually-hidden">
                {{- 'accessibility.localization_region_and_language' | t -}}
              </span>

              {%- if show_country and show_language -%}
                <span>/</span>
              {%- endif -%}

              {%- if show_language -%}
                <span>{{ localization.language.iso_code | upcase }}</span>
              {%- endif -%}
              <span class="svg-wrapper icon-caret">
                {{- 'icon-caret.svg' | inline_asset_content -}}
              </span>
            </button>

            <div
              class="localization-wrapper right-bound color-{{ settings.popover_color_scheme }}"
              hidden
              ref="panel"
              id="dropdown-localization-results-{{ section.id }}"
            >
              {% render 'localization-form',
                show_country: show_country,
                show_language: show_language,
                localization_style: 'dropdown',
                form_style: form_style,
                form_id: section.id
              %}
            </div>
          </dropdown-localization-component>
        {% endif %}
      {%- endif -%}
    </div>
  </div>
</div>

{% stylesheet %}
  .header-top {
    border-block-end: var(--border-bottom-width) solid var(--color-border);
  }

  /* Section background for header-top */
  .header-top {
    position: relative;
  }

  .header-top__background {
    position: absolute;
    inset: 0;
    z-index: -1;
  }

  .header-top__container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--spacing-4);
    width: 100%;
  }

  .header-top__left {
    display: flex;
    align-items: center;
    flex: 0 0 auto;
    min-width: 120px;
  }

  .header-top__center {
    display: flex;
    align-items: center;
    justify-content: center;
    flex: 1;
    text-align: center;
  }

  .header-top__right {
    display: flex;
    align-items: center;
    gap: var(--spacing-3);
    flex: 0 0 auto;
    min-width: 120px;
    justify-content: flex-end;
  }

  .header-top__announcement {
    position: relative;
  }

  .header-top__text {
    margin: 0;
  }

  .header-top__link {
    position: absolute;
    inset: 0;
  }

  .header-top__localization-item {
    display: flex;
    align-items: center;
  }

  .header-top__localization-item .localization-form {
    display: flex;
    align-items: center;
  }

  .header-top__localization-item .localization-form__select {
    background: transparent;
    border: none;
    padding: 0;
    font-size: inherit;
    color: inherit;
    cursor: pointer;
  }

  /* Dropdown Localization Styles */
  .header-top__right .dropdown-localization {
    display: flex;
    align-items: center;
  }

  .header-top__right .dropdown-localization__button {
    display: flex;
    position: relative;
    align-items: center;
    gap: 4px;
    font-family: var(--menu-localization-font);
    font-size: var(--menu-localization-font-size);
    font-weight: var(--menu-top-level-font-weight, 400);
    padding-inline: var(--padding-2xs);
    margin-inline: calc(-1 * var(--padding-2xs));
    color: inherit;
    background: transparent;
    border: none;
    cursor: pointer;
    padding: 0;
  }

  .header-top__right .dropdown-localization__button .svg-wrapper.icon-caret {
    height: var(--icon-size-xs);
    width: var(--icon-size-xs);
    flex-shrink: 0;
    transition: transform var(--animation-speed) var(--animation-easing);
  }

  .header-top__right .dropdown-localization__button .icon-flag {
    width: var(--menu-localization-font-size, var(--icon-size-sm));
    height: var(--menu-localization-font-size, var(--icon-size-sm));
    clip-path: circle(50%);
    background-position: center;
    background-size: cover;
    margin-inline-end: 4px;
    position: relative;
  }

  .header-top__right .dropdown-localization__button .icon-flag::after {
    content: '';
    position: absolute;
    inset: 0;
    box-shadow: inset 0 0 var(--size-shadow, 2px) var(--color-shadow);
    border-radius: 50%;
  }

  .header-top__right .dropdown-localization__button[aria-expanded='true'] .icon-caret svg {
    transform: rotate(180deg);
  }

  .header-top__right dropdown-localization-component {
    position: relative;
    background-color: transparent;
  }

  .header-top__right dropdown-localization-component .localization-wrapper {
    box-shadow: var(--shadow-popover);
    border: var(--style-border-popover);
    background-color: var(--color-background);
    max-height: 27.5rem;
    position: absolute;
    top: calc(100% + 10px);
    right: 0;
    z-index: calc(var(--layer-header-menu) + 1);
    border-radius: var(--style-border-radius-popover);
    transition-property: display, opacity, translate;
    transition-duration: 0.3s;
    transition-timing-function: var(--ease-out-quad);
    transition-behavior: allow-discrete;
    translate: 0 20px;
    opacity: 0;
  }

  .header-top__right dropdown-localization-component .localization-wrapper:not([hidden]) {
    translate: 0 0;
    opacity: 1;
  }

  @starting-style {
    .header-top__right dropdown-localization-component .localization-wrapper:not([hidden]) {
      translate: 0 20px;
      opacity: 0;
    }
  }

  .header-top__right dropdown-localization-component .localization-form__list {
    max-height: 20.5rem;
  }

  .header-top__right dropdown-localization-component .country-filter {
    position: relative;
    padding: 8px;
  }

  .header-top__right dropdown-localization-component .country-filter__input {
    border: none;
  }

  .header-top__right dropdown-localization-component .localization-form__list-item {
    margin-inline: 8px;
  }

  .header-top__right dropdown-localization-component .language-selector.language-selector {
    padding: 10px 8px 10px 16px;
  }

  .header-top__right dropdown-localization-component .localization-form__currency {
    width: max-content;
    opacity: 0;
    visibility: hidden;
    transition: none;
  }

  .header-top__right dropdown-localization-component .localization-form__select:hover {
    background-color: rgb(var(--color-primary-hover-rgb) / var(--opacity-8));
  }

  .header-top__right
    dropdown-localization-component
    :is(
      .localization-form__list-item:hover,
      .localization-form__list-item[aria-selected='true'],
      .localization-form__list-item[aria-current='true']
    )
    .localization-form__currency {
    opacity: 1;
    color: var(--color-foreground-muted);
    transition: opacity var(--animation-speed-slow) var(--animation-easing);
    visibility: visible;
  }

  .header-top__right .dropdown-localization .language-selector:where(:not(.top-shadow)) {
    font-weight: var(--menu-top-level-font-weight, 400);
  }

  .header-top__right .dropdown-localization:not(dropdown-localization-component) .language-selector {
    font-family: var(--menu-localization-font);
    font-size: var(--menu-localization-font-size);
  }

  /* Social icons styles */
  .social-icons__wrapper {
    display: flex;
    gap: var(--gap-sm);
    flex-wrap: wrap;
    justify-content: flex-start;
  }

  .social-icons__icon-wrapper {
    display: flex;
    align-items: center;
    justify-content: center;
    height: var(--icon-size-lg);
    transition: transform 200ms ease-out;
  }

  .social-icons__icon-wrapper:hover {
    transform: scale(1.15);
  }

  .social-icons__icon-wrapper:active {
    transform: scale(0.95);
  }

  .social-icons__icon-wrapper a {
    display: flex;
    align-items: center;
    justify-content: center;
    transition: color 200ms ease-out;
  }

  .social-icons__icon-wrapper:hover a {
    color: var(--color-primary);
  }

  .social-icons__icon {
    display: flex;
    flex-shrink: 0;
    width: var(--icon-size-lg);
    height: var(--icon-size-lg);
    transition: transform 200ms ease-out, fill 200ms ease-out;
  }

  .social-icons__icon-wrapper:hover .social-icons__icon {
    transform: scale(1.15);
    fill: var(--color-primary);
  }

  .social-icons__icon-wrapper:has(.social-icons__icon path) {
    width: var(--icon-size-lg);
  }

  .social-icons__icon-wrapper:has(.social-icons__icon path) .social-icons__icon {
    display: block;
  }

  .social-icons__icon-wrapper:has(.social-icons__icon path) .social-icons__icon-label {
    display: none;
  }

  @media screen and (max-width: 749px) {
    .header-top__container {
      flex-direction: row;
      gap: 0;
      justify-content: center;
    }

    .header-top__left,
    .header-top__right {
      display: none;
    }

    .header-top__center {
      width: 100%;
      justify-content: center;
      min-width: auto;
    }
  }
{% endstylesheet %}

